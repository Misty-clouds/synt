  },
  "dependencies": {
    "@synt/scenarios": "workspace:*",
    "@synt/shared": "workspace:*",
    "@synt/splunk": "workspace:*"
  },
  "devDependencies": {
    "@synt/typescript-config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
