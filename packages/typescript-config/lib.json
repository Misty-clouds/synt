{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Library (CommonJS)",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2023"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "isolatedModules": false,
    "rootDir": "./src",
    "outDir": "./dist"
  }
}
