# ── apps/web — Synt web environment (EXAMPLE / committed) ────────────────────
# Copy to apps/web/.env and fill in. NEXT_PUBLIC_* is inlined at BUILD time, so set
# it before `pnpm --filter web build` (or before `pnpm --filter web dev`).

# Base URL of the Synt API.
NEXT_PUBLIC_API_URL=http://localhost:3001
