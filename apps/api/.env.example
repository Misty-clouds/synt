# ── apps/api — Synt API environment (EXAMPLE / committed) ────────────────────
# Copy to apps/api/.env and fill in. With USE_MOCK_SPLUNK=true the API runs fully
# offline (in-memory Splunk + deterministic models + in-memory store + local PDFs).
# Set the real values + USE_MOCK_SPLUNK=false to go live.

# Run offline (mock Splunk + mock hosted model). false = real MCP + hosted models.
USE_MOCK_SPLUNK=true

# App state — empty = in-memory store. Set to persist to MongoDB.
MONGODB_URI=mongodb://localhost:27017/synt

# Splunk MCP Server (the agent's hands)
SPLUNK_MCP_URL=http://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=

# Splunk core: token auth + HEC (scenario seeding)
SPLUNK_TOKEN=
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# Splunk hosted models (the agent's brain)
SPLUNK_MODEL_ENDPOINT=
SPLUNK_MODEL_TOKEN=
SPLUNK_MODEL_NAME=

# Cloudflare R2 (PDF case files) — empty = store PDFs on local disk
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=synt-casefiles

# Runtime
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
