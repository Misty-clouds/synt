# ── Synt environment ────────────────────────────────────────────────────────
# Copy to .env and fill in. With USE_MOCK_SPLUNK=true (the default) the whole app
# runs offline with an in-memory Splunk + deterministic models + local PDF storage,
# so you can demo with zero external services. Set the real values to go live.

# Run fully offline (mock Splunk + mock hosted model). Set to false to use real MCP + models.
USE_MOCK_SPLUNK=true

# ── App state (MongoDB) ──────────────────────────────────────────────────────
# Leave empty to use the in-memory store. Set to persist investigations/traces/case files.
MONGODB_URI=

# ── Splunk MCP Server (the agent's hands) ────────────────────────────────────
SPLUNK_MCP_URL=
SPLUNK_MCP_TOKEN=

# ── Splunk core (token auth + HEC for scenario seeding) ──────────────────────
SPLUNK_TOKEN=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# ── Splunk hosted models (the agent's brain) ─────────────────────────────────
SPLUNK_MODEL_ENDPOINT=
SPLUNK_MODEL_TOKEN=
SPLUNK_MODEL_NAME=

# ── Cloudflare R2 (PDF case files) ───────────────────────────────────────────
# Leave empty to store PDFs on local disk and serve them from the API.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=synt-casefiles

# ── API runtime ──────────────────────────────────────────────────────────────
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# ── Web (must be set at build time for the browser bundle) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
